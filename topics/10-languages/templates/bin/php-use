#!/usr/bin/env bash
# php-use — switch the default PHP on this machine.
# Managed by dev-bootstrap / 10-languages.
#
# Linux/WSL: uses update-alternatives (sudo required).
# macOS:     uses brew unlink+link (no sudo; re-links php@X.Y).
#
# Usage:
#   php-use <version>        # e.g. php-use 8.4
#   php-use --list           # show installed versions + current default
#   php-use --current        # show current default version
#
# Versions currently installed are auto-discovered — no pre-declared list.
# Safe to re-run; idempotent when already on the requested version.

set -euo pipefail

# ─── OS detection ─────────────────────────────────────────────────────
OS="unknown"
case "$(uname -s)" in
    Darwin) OS="mac" ;;
    Linux)
        if grep -qi microsoft /proc/version 2>/dev/null; then
            OS="wsl"
        else
            OS="linux"
        fi
        ;;
esac

# ─── discovery helpers ───────────────────────────────────────────────
list_installed_linux() {
    # Lists every php8.X binary in /usr/bin, stripped to just the version.
    for bin in /usr/bin/php[0-9].[0-9]; do
        [[ -x "$bin" ]] || continue
        basename "$bin" | sed 's/^php//'
    done | sort -V
}

list_installed_mac() {
    # brew formulas php@X.Y — returns versions that are installed (may not be linked).
    brew list --formula 2>/dev/null | grep -oE '^php@[0-9]+\.[0-9]+$' | sed 's/^php@//' | sort -V
}

current_linux() {
    command -v php >/dev/null 2>&1 || { echo "(none)"; return; }
    php -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION;' 2>/dev/null || echo "(unknown)"
}

current_mac() {
    current_linux
}

# ─── list mode ───────────────────────────────────────────────────────
cmd_list() {
    local current
    case "$OS" in
        wsl|linux) current="$(current_linux)" ;;
        mac)       current="$(current_mac)" ;;
    esac

    echo "Installed PHP versions:"
    local versions
    case "$OS" in
        wsl|linux) versions="$(list_installed_linux)" ;;
        mac)       versions="$(list_installed_mac)" ;;
    esac

    if [[ -z "$versions" ]]; then
        echo "  (none installed — run 'bash ~/dev-bootstrap/bootstrap.sh')"
        return 0
    fi

    while IFS= read -r v; do
        if [[ "$v" == "$current" ]]; then
            printf "  * %s  (default)\n" "$v"
        else
            printf "    %s\n" "$v"
        fi
    done <<< "$versions"
}

cmd_current() {
    case "$OS" in
        wsl|linux) current_linux ;;
        mac)       current_mac ;;
    esac
}

# ─── switch: Linux/WSL ───────────────────────────────────────────────
switch_linux() {
    local target="$1"
    if [[ ! -x "/usr/bin/php${target}" ]]; then
        echo "✗ PHP $target not installed (missing /usr/bin/php${target})" >&2
        echo "  Installed: $(list_installed_linux | tr '\n' ' ')" >&2
        exit 1
    fi

    if [[ "$(current_linux)" == "$target" ]]; then
        echo "✓ PHP $target is already the default"
        return 0
    fi

    echo "→ switching PHP default to $target (sudo required)"
    for bin in php phar phar.phar phpize php-config; do
        local path="/usr/bin/${bin}${target}"
        if [[ -x "$path" ]]; then
            sudo update-alternatives --set "$bin" "$path" >/dev/null 2>&1 || \
                echo "  (warn) update-alternatives couldn't set $bin" >&2
        fi
    done

    echo "✓ now using PHP $(current_linux) — composer will follow on next invocation"
}

# ─── switch: macOS ───────────────────────────────────────────────────
switch_mac() {
    local target="$1"
    if ! brew list --formula "php@${target}" >/dev/null 2>&1; then
        echo "✗ php@${target} not installed (brew install php@${target})" >&2
        echo "  Installed: $(list_installed_mac | tr '\n' ' ')" >&2
        exit 1
    fi

    if [[ "$(current_mac)" == "$target" ]]; then
        echo "✓ PHP $target is already the default"
        return 0
    fi

    echo "→ switching PHP default to $target"
    for v in $(list_installed_mac); do
        if [[ "$v" != "$target" ]]; then
            brew unlink "php@${v}" >/dev/null 2>&1 || true
        fi
    done
    brew link --force --overwrite "php@${target}" >/dev/null 2>&1

    echo "✓ now using PHP $(current_mac)"
}

# ─── dispatch ────────────────────────────────────────────────────────
case "${1:-}" in
    ""|-h|--help)
        sed -n '2,15p' "$0" | sed 's/^# //; s/^#$//'
        exit 0
        ;;
    --list|-l)
        cmd_list
        ;;
    --current|-c)
        cmd_current
        ;;
    *)
        case "$OS" in
            wsl|linux) switch_linux "$1" ;;
            mac)       switch_mac "$1" ;;
            *)
                echo "✗ unsupported OS: $(uname -s)" >&2
                exit 1
                ;;
        esac
        ;;
esac
