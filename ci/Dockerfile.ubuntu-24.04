# syntax=docker/dockerfile:1
# Dockerfile.ubuntu-24.04 — hermetic smoke-test image for dev-bootstrap.
#
# Mirrors a fresh WSL2 Ubuntu 24.04 install as closely as a container allows:
#   - non-root `henry` user with NOPASSWD sudo
#   - Phase 0 of docs/onboard-new-machine.md pre-installed (git, curl, ca-certs)
#   - a docker-layer sed on lib/detect-os.sh so it emits "wsl" (upstream
#     lib/ is NOT modified — see rationale below)
#
# Built and run by ci/smoke-test.sh — do not invoke docker build directly
# unless you know what you're doing.

FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Phase 0 of the onboarding doc is git + curl + ca-certificates. That's the
# only tooling a human user installs before running bootstrap.sh.
#
# We also pre-install three packages that ship by default in WSL's Ubuntu
# cloud image but are absent from `ubuntu:24.04` minimal:
#   - sudo:                       base image has no sudo binary
#   - locales + tzdata:           apt installers whinge without a UTF-8 locale
#                                 and tzdata hangs on interactive prompt
#   - software-properties-common: provides `add-apt-repository`, which
#                                 10-languages uses to enable the ondrej/php
#                                 PPA for PHP 8.4
#
# Including these here treats "Docker minimal-base vs WSL cloud-image"
# divergence as uninteresting noise rather than a bootstrap regression.
# Everything else — even compilers — is expected to be installed by the
# bootstrap itself.
RUN apt-get update -qq \
    && apt-get install -y -qq --no-install-recommends \
        git \
        curl \
        ca-certificates \
        sudo \
        locales \
        tzdata \
        software-properties-common \
    && locale-gen en_US.UTF-8 \
    && update-locale LANG=en_US.UTF-8 LC_ALL=en_US.UTF-8 \
    && rm -rf /var/lib/apt/lists/*

ENV LANG=en_US.UTF-8 \
    LC_ALL=en_US.UTF-8 \
    TZ=America/Sao_Paulo

# Non-root `henry` with NOPASSWD sudo. NOPASSWD is a container ergonomics
# concession — real machines use regular sudo with timestamp cache.
RUN useradd -m -s /bin/bash henry \
    && echo 'henry ALL=(ALL) NOPASSWD:ALL' > /etc/sudoers.d/99-henry \
    && chmod 440 /etc/sudoers.d/99-henry

# Bring the repo in as `henry`. `.dockerignore` strips `.git` + log noise
# so the build context stays tight.
COPY --chown=henry:henry . /home/henry/dev-bootstrap

# Docker-layer coercion: force lib/detect-os.sh to emit "wsl" instead of "linux".
#
# Why: out of the 7 topics the smoke test targets, 5 (00-core, 10-languages,
# 20-terminal-ux, 40-tmux, 80-claude-code) only ship `install.wsl.sh` +
# `install.mac.sh` — no generic `install.sh`, no `install.linux.sh`. Under
# pure-Linux detection the bootstrap would silently skip them as "no
# installer", producing a green smoke test that exercised nothing.
#
# The install.wsl.sh scripts are apt-based and run fine on non-WSL Ubuntu;
# they're gated behind the WSL tag by convention, not by WSL-specific APIs.
#
# Approach: patch the image's COPY of lib/detect-os.sh to grep a file we
# own (/etc/fake-proc-version containing the magic "microsoft" string)
# instead of /proc/version. We do not touch the repo on disk — this patch
# lives entirely inside the image layer. Bind-mounting /proc/version isn't
# an option (kernel-virtual, needs --privileged).
RUN printf 'Linux version 5.15.0-microsoft-standard (docker-ci-smoke) #1 SMP Ubuntu 24.04 LTS\n' \
        > /etc/fake-proc-version \
    && sed -i \
        's|/proc/version|/etc/fake-proc-version|g' \
        /home/henry/dev-bootstrap/lib/detect-os.sh \
    && test "$(bash /home/henry/dev-bootstrap/lib/detect-os.sh)" = "wsl" \
        || (echo 'detect-os.sh did not report wsl after patch' >&2 && exit 1)

USER henry
WORKDIR /home/henry
ENV HOME=/home/henry

# Default CMD runs the bootstrap non-interactively. `smoke-test.sh` overrides
# this with its own bash -c wrapper so it can pass SKIP_TOPICS cleanly.
CMD ["bash", "/home/henry/dev-bootstrap/bootstrap.sh", "--non-interactive"]
